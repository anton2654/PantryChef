@model PantryChef.Web.Models.InventoryIndexViewModel

@{
    ViewData["Title"] = "Мій Холодильник";
}

<div class="container mt-4">
    <h2 class="mb-4">Мій Холодильник</h2>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success" role="alert">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    <form method="post" asp-action="AddIngredient" class="mb-4 p-3 border rounded bg-light">
        <h5 class="mb-3">Додати інгредієнт</h5>
        <div class="row g-3 align-items-end">
            <div class="col-12 col-md-6">
                <label for="ingredientId" class="form-label fw-bold">Інгредієнт</label>
                <select name="ingredientId" id="ingredientId" class="form-select" required>
                    <option value="">Оберіть інгредієнт</option>
                    @foreach (var ingredient in Model.AvailableIngredients)
                    {
                        <option value="@ingredient.Id">@ingredient.Name (@ingredient.Category)</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label for="quantity" class="form-label fw-bold">Кількість</label>
                <input type="number" name="quantity" id="quantity" class="form-control" min="0.1" step="0.1" value="@Model.AddQuantity.ToString(System.Globalization.CultureInfo.InvariantCulture)" required />
            </div>
            <div class="col-12 col-md-3">
                <button type="submit" class="btn btn-success w-100">Додати</button>
            </div>
        </div>
    </form>

    <form method="get" asp-action="Index" class="mb-4 d-flex flex-wrap align-items-center gap-3">
        <label for="category" class="fw-bold mb-0">Фільтр за категорією:</label>
        <select name="category" id="category" class="form-select w-auto">
            <option value="">Всі категорії</option>
            @foreach (var cat in Model.AvailableCategories)
            {
                if (Model.SelectedCategory == cat)
                {
                    <option value="@cat" selected>@cat</option>
                }
                else
                {
                    <option value="@cat">@cat</option>
                }
            }
        </select>
        <button type="submit" class="btn btn-primary px-4">Застосувати</button>

        <div class="ms-auto d-flex align-items-center gap-2">
            <input type="text" name="searchQuery" value="@Model.SearchQuery" class="form-control" minlength="@Model.MinSearchLength" placeholder="Пошук інгредієнта (мін. @Model.MinSearchLength симв.)..." style="width: 250px;" />
            <button type="submit" class="btn btn-outline-secondary">Знайти</button>
            
            @if (!string.IsNullOrEmpty(Model.SearchQuery) || !string.IsNullOrEmpty(Model.SelectedCategory))
            {
                <a asp-action="Index" class="btn btn-outline-danger" title="Скинути всі фільтри">✕</a>
            }
        </div>
    </form>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-5 g-4">
        @if (!Model.Inventory.Any())
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted fs-5">У цій категорії поки що немає продуктів.</p>
                <a asp-action="Index" class="btn btn-outline-secondary">Скинути фільтр</a>
            </div>
        }
        else
        {
            @foreach (var item in Model.Inventory)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm" style="border-radius: 12px; background-color: #fcfcfc;">
                        <div style="height: 150px; overflow: hidden; border-top-left-radius: 12px; border-top-right-radius: 12px; background-color: #d9d9d9;">
                            @if (!string.IsNullOrEmpty(item.Ingredient.Photo))
                            {
                                <img src="@item.Ingredient.Photo" alt="@item.Ingredient.Name" class="w-100 h-100" style="object-fit: cover;" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100 text-white">
                                    <i class="bi bi-basket fs-1"></i>
                                </div>
                            }
                        </div>

                        <div class="card-body text-center d-flex flex-column">
                            <h6 class="card-title fw-bold mb-1">@item.Ingredient.Name</h6>
                            <p class="text-muted small mb-0">@item.Ingredient.Category</p>
                            
                            <form asp-action="UpdateQuantity" method="post" class="mt-2 mb-3 d-flex align-items-center justify-content-center gap-1">
                                <input type="hidden" name="ingredientId" value="@item.IngredientId" />
                                <input type="number" name="quantity" value="@item.Quantity" class="form-control form-control-sm text-center border-success-subtle text-success fw-bold" style="width: 80px; border-radius: 8px;" min="0.1" step="0.1" required />
                                <span class="text-muted small">г/шт</span>
                                <button type="submit" class="btn btn-sm btn-success text-white px-2" style="border-radius: 8px;" title="Зберегти кількість">
                                    ✓
                                </button>
                            </form>

                            <div class="mt-auto d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@item.IngredientId" class="btn btn-sm btn-outline-primary w-50" style="border-radius: 8px;">
                                    Деталі
                                </a>
                                <form asp-action="RemoveIngredient" method="post" class="w-50">
                                    <input type="hidden" name="ingredientId" value="@item.IngredientId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger w-100" style="border-radius: 8px;" onclick="return confirm('Ви впевнені, що хочете видалити цей продукт з холодильника?');">
                                        Видалити
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
    }
</style>