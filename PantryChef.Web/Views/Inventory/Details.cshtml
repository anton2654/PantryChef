@model PantryChef.Web.Models.IngredientDetailsViewModel

@{
    ViewData["Title"] = Model.Ingredient.Name;
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Холодильник</a></li>
            <li class="breadcrumb-item active">@Model.Ingredient.Name</li>
        </ol>
    </nav>

    <div class="row g-5">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 20px;">
                <img src="@Model.Ingredient.Photo" class="img-fluid" alt="@Model.Ingredient.Name" style="min-height: 300px; object-fit: cover;">
            </div>
        </div>

        <div class="col-md-7">
            <h1 class="display-5 fw-bold text-primary">@Model.Ingredient.Name</h1>
            <p class="badge bg-info text-dark fs-6">@Model.Ingredient.Category</p>
            
            <div class="my-4 p-4 bg-light" style="border-radius: 15px; border-left: 5px solid #0d6efd;">
                <h4 class="fw-bold">Запас у холодильнику: <span class="text-primary">@Model.Quantity г/шт</span></h4>
            </div>

            <h5 class="fw-bold mb-3">Харчова цінність на 100г:</h5>
            <div class="row text-center g-3">
                <div class="col-3">
                    <div class="p-3 border rounded shadow-sm bg-white">
                        <div class="small text-muted">Калорії</div>
                        <div class="fw-bold">@Model.Ingredient.Calories ккал</div>
                    </div>
                </div>
                <div class="col-3">
                    <div class="p-3 border rounded shadow-sm bg-white">
                        <div class="small text-muted">Білки</div>
                        <div class="fw-bold">@Model.Ingredient.Proteins г</div>
                    </div>
                </div>
                <div class="col-3">
                    <div class="p-3 border rounded shadow-sm bg-white">
                        <div class="small text-muted">Жири</div>
                        <div class="fw-bold">@Model.Ingredient.Fats г</div>
                    </div>
                </div>
                <div class="col-3">
                    <div class="p-3 border rounded shadow-sm bg-white">
                        <div class="small text-muted">Вуглеводи</div>
                        <div class="fw-bold">@Model.Ingredient.Carbohydrates г</div>
                    </div>
                </div>
            </div>

            <div class="mt-5">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Назад до списку</a>
            </div>
        </div>
    </div>
</div>