@{
    ViewData["Title"] = "Forgot password confirmation";
    var resetPasswordLink = ViewData["ResetPasswordLink"] as string;
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <h1 class="h3 mb-3">Check your email</h1>
        <p>
            If an account with this email exists, a password reset link has been generated.
        </p>

        @if (!string.IsNullOrWhiteSpace(resetPasswordLink))
        {
            <div class="alert alert-warning mt-3">
                Development helper: open this link to reset password:
                <a href="@resetPasswordLink">Reset password</a>
            </div>
        }

        <a asp-action="Login" class="btn btn-outline-primary mt-2">Back to login</a>
    </div>
</div>
