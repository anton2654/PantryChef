@model PantryChef.Web.Models.RecipeIndexViewModel

@{
    ViewData["Title"] = "Меню страв";
}

<div class="container mt-4">
    <h2 class="mb-4">Меню страв</h2>

    <form method="get" asp-action="Filter" class="mb-4 d-flex align-items-center gap-3">
        <label for="category" class="fw-bold mb-0">Фільтр за категорією:</label>
        <select name="category" id="category" class="form-select w-auto">
            @foreach (var cat in Model.Categories)
            {
                if (cat.IsSelected)
                {
                    <option value="@cat.Value" selected>@cat.Label</option>
                }
                else
                {
                    <option value="@cat.Value">@cat.Label</option>
                }
            }
        </select>
        <button type="submit" class="btn btn-primary">Застосувати</button>
    </form>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @if (!Model.Recipes.Any())
        {
            <div class="col-12">
                <p class="text-muted">У цій категорії поки що немає страв.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model.Recipes)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm" style="border-radius: 12px; background-color: #fcfcfc;">
                        <div style="height: 200px; overflow: hidden; border-top-left-radius: 12px; border-top-right-radius: 12px; background-color: #d9d9d9;">
                            @if (!string.IsNullOrEmpty(item.Photo))
                            {
                                <img src="@item.Photo" alt="@item.Name" class="w-100 h-100" style="object-fit: cover;" />
                            }
                        </div>
                        <div class="card-body text-center d-flex flex-column">
                            <h5 class="card-title fw-bold mb-1">@item.Name</h5>
                            <p class="text-muted small mb-3">Категорія: @item.Category</p>
                            
                            <div class="mt-auto">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary w-100" style="border-radius: 8px;">Деталі</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>