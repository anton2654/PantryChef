@model PantryChef.Web.Models.RecipeIndexViewModel

@{
    ViewData["Title"] = "Страви";
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show rounded-3" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex gap-2 flex-wrap">
            @foreach (var category in Model.Categories)
            {
                var url = string.IsNullOrWhiteSpace(category.Value)
                    ? Url.Action("Filter", "Recipe")
                    : Url.Action("Filter", "Recipe", new { category = category.Value });

                var buttonClass = category.IsSelected
                    ? "btn btn-outline-secondary rounded-pill px-4 active"
                    : "btn btn-light rounded-pill px-3";

                <a class="@buttonClass" href="@url">@category.Label</a>
            }
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-5 g-4">
        @foreach (var recipe in Model.Recipes)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm position-relative" style="border-radius: 12px; background-color: #fcfcfc;">

                    <div style="height: 150px; overflow: hidden; border-top-left-radius: 12px; border-top-right-radius: 12px; background-color: #d9d9d9;">
                        @if (!string.IsNullOrEmpty(recipe.Photo))
                        {
                            <img src="@recipe.Photo" alt="@recipe.Name" class="w-100 h-100" style="object-fit: cover;" />
                        }
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h6 class="card-title fw-bold mb-1">@recipe.Name</h6>

                        <p class="card-text text-muted" style="font-size: 0.8rem;">
                            @(recipe.Description != null && recipe.Description.Length > 50
                                ? recipe.Description.Substring(0, 50) + "..."
                                : recipe.Description)
                        </p>

                        <a asp-controller="Recipe" asp-action="Details" asp-route-id="@recipe.Id" class="stretched-link"></a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>