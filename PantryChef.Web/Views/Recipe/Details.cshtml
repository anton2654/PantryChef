@model PantryChef.Data.Entities.Recipe

@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            @if (!string.IsNullOrEmpty(Model.Photo))
            {
                <img src="@Model.Photo" class="img-fluid rounded-3 shadow-sm" alt="@Model.Name" />
            }
            else
            {
                <div class="bg-secondary rounded-3" style="height: 300px;"></div>
            }
        </div>

        <div class="col-md-6">
            <h2 class="fw-bold">@Model.Name</h2>
            <p class="text-muted">@Model.Description</p>

            <div class="card border-0 shadow-sm mt-4 p-3" style="background-color: #f8f9fa; border-radius: 12px;">
                <h5 class="fw-bold">Харчова цінність</h5>
                <ul class="list-unstyled mb-0">
                    <li>Калорії: <strong>@Model.Calories ккал</strong></li>
                    <li>Білки: <strong>@Model.Proteins г</strong></li>
                    <li>Жири: <strong>@Model.Fats г</strong></li>
                    <li>Вуглеводи: <strong>@Model.Carbohydrates г</strong></li>
                </ul>

                <form asp-controller="Recipe" asp-action="CalculateNutrition" method="post" class="mt-3">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-success rounded-pill px-4">
                        <i class="bi bi-calculator"></i> Перерахувати КБЖВ
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">← Повернутися до списку</a>
    </div>
</div>