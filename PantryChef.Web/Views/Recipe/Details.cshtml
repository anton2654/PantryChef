@model PantryChef.Web.Models.RecipeDetailsViewModel

@{
    ViewData["Title"] = Model.Recipe.Name;
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            @if (!string.IsNullOrEmpty(Model.Recipe.Photo))
            {
                <img src="@Model.Recipe.Photo" class="img-fluid rounded-3 shadow-sm" alt="@Model.Recipe.Name" onerror="this.onerror=null;this.src='https://placehold.co/800x500/e9ecef/6c757d?text=No+Image';" />
            }
            else
            {
                <img src="https://placehold.co/800x500/e9ecef/6c757d?text=No+Image" class="img-fluid rounded-3 shadow-sm" alt="Немає зображення" />
            }
        </div>

        <div class="col-md-6">
            <h2 class="fw-bold">@Model.Recipe.Name</h2>
            <p class="text-muted">@Model.Recipe.Description</p>

            <div class="card border-0 shadow-sm mt-4 p-3" style="background-color: #f8f9fa; border-radius: 12px;">
                <h5 class="fw-bold">Харчова цінність</h5>
                <ul class="list-unstyled mb-0">
                    <li>Калорії: <strong>@Model.Calories.ToString("0.0") ккал</strong></li>
                    <li>Білки: <strong>@Model.Proteins.ToString("0.0") г</strong></li>
                    <li>Жири: <strong>@Model.Fats.ToString("0.0") г</strong></li>
                    <li>Вуглеводи: <strong>@Model.Carbohydrates.ToString("0.0") г</strong></li>
                </ul>

                <form asp-controller="Recipe" asp-action="CalculateNutrition" method="post" class="mt-3">
                    <input type="hidden" name="id" value="@Model.Recipe.Id" />
                    <button type="submit" class="btn btn-success rounded-pill px-4">
                        <i class="bi bi-calculator"></i> Перерахувати КБЖВ
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <div class="card shadow-sm p-3">
            <h5 class="fw-bold">Інгредієнти</h5>
            @if (Model.Recipe.RecipeIngredients == null || !Model.Recipe.RecipeIngredients.Any())
            {
                <p class="text-muted">Інгредієнти відсутні.</p>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var ri in Model.Recipe.RecipeIngredients)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@ri.Ingredient?.Name</strong>
                                <div class="text-muted small">@ri.Ingredient?.Category</div>
                            </div>
                            <span class="badge bg-secondary">@ri.Quantity.ToString("0.##") г</span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <div class="mt-4">
        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">← Повернутися до списку</a>
            <a asp-action="Edit" asp-route-id="@Model.Recipe.Id" class="btn btn-outline-primary rounded-pill">Редагувати</a>
            <a asp-action="Delete" asp-route-id="@Model.Recipe.Id" class="btn btn-outline-danger rounded-pill">Видалити</a>
        </div>
    </div>
</div>