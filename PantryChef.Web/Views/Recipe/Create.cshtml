@model PantryChef.Web.Models.RecipeCreateViewModel

@{
    ViewData["Title"] = "Додати страву";
}

<div class="container mt-4 app-page">
    <div class="page-heading">
        <h2 class="mb-1">Додати страву</h2>
        <p class="text-muted mb-0">Створіть власний рецепт або швидко підтягніть назву й опис із TheMealDB.</p>
    </div>

    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <form asp-action="Create" method="post" class="card pantry-card border-0 shadow-sm p-4">
        <div class="row g-3">
            <div class="col-12">
                <div class="mealdb-panel border rounded p-3 bg-light-subtle"
                     data-areas-url="@Url.Action("MealDbAreas", "Recipe")"
                     data-meals-url="@Url.Action("MealDbMeals", "Recipe")"
                     data-instructions-url="@Url.Action("MealDbInstructions", "Recipe")">
                    <h5 class="mb-3">Швидке заповнення з TheMealDB</h5>
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label for="mealdb-area" class="form-label fw-bold">Країна</label>
                            <select id="mealdb-area" class="form-select">
                                <option value="">Оберіть країну</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6">
                            <label for="mealdb-meal" class="form-label fw-bold">Назва страви з API</label>
                            <select id="mealdb-meal" class="form-select" disabled>
                                <option value="">Спочатку оберіть країну</option>
                            </select>
                        </div>
                    </div>
                    <small id="mealdb-status" class="text-muted d-block mt-2">Оберіть країну, потім страву. Поля "Назва" і "Опис" заповняться автоматично.</small>
                </div>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="Name" class="form-label fw-bold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="Category" class="form-label fw-bold"></label>
                <select asp-for="Category" asp-items="Model.AvailableCategories" class="form-select">
                    <option value="">Оберіть категорію</option>
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label fw-bold"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Photo" class="form-label fw-bold"></label>
                <input asp-for="Photo" class="form-control" />
                <small class="text-muted">Можна вставити прямий URL картинки або URL сторінки зі статтею.</small>
                <span asp-validation-for="Photo" class="text-danger"></span>
            </div>
            <div class="col-6 col-md-3">
                <label asp-for="Calories" class="form-label fw-bold"></label>
                <input asp-for="Calories" class="form-control" min="0" step="0.1" />
                <span asp-validation-for="Calories" class="text-danger"></span>
            </div>
            <div class="col-6 col-md-3">
                <label asp-for="Proteins" class="form-label fw-bold"></label>
                <input asp-for="Proteins" class="form-control" min="0" step="0.1" />
                <span asp-validation-for="Proteins" class="text-danger"></span>
            </div>
            <div class="col-6 col-md-3">
                <label asp-for="Fats" class="form-label fw-bold"></label>
                <input asp-for="Fats" class="form-control" min="0" step="0.1" />
                <span asp-validation-for="Fats" class="text-danger"></span>
            </div>
            <div class="col-6 col-md-3">
                <label asp-for="Carbohydrates" class="form-label fw-bold"></label>
                <input asp-for="Carbohydrates" class="form-control" min="0" step="0.1" />
                <span asp-validation-for="Carbohydrates" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-4 d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-success">Зберегти</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
